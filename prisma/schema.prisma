generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Vaga {
  id                    String          @id @default(cuid())
  titulo                String
  departamento          String
  modalidade            String          @default("Presencial")
  descricaoAtividades   String
  habilidadesDesejaveis String?
  curso                 String
  cargaHoraria          Int
  bolsaAuxilio          Decimal
  valeTransporte        Decimal
  prazoInscricoes       DateTime
  numeroVagas           Int
  responsavel           String
  etapas                EtapaProcesso[]
  status                String          @default("ativa")
  criadoEm              DateTime        @default(now())
  atualizadoEm          DateTime        @updatedAt
}

model EtapaProcesso {
  id     String @id @default(cuid())
  ordem  Int
  titulo String
  vagaId String
  vaga   Vaga   @relation(fields: [vagaId], references: [id])
}
